            mapfile = os.path.join(output_dir, file_name_raw + '_map.uc'),
            table_txt = os.path.join(output_dir, file_name_raw + '_pre_otu_table.txt') if strategy == "otu" else os.path.join(output_dir, file_name_raw + '_pre_asv_table.txt')
        params:
