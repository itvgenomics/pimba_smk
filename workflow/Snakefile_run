            """
            mkdir -p {output_dir}/lulu_output
            echo "Running the BLAST Container - makeblastdb: "
            makeblastdb -in {input.fasta_file} -out {output_dir}/lulu_output/{file_name_raw}_otus.fasta \
            -parse_seqids -dbtype nucl > {log} 2>&1

